{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd src/main/client && npm ci",
  "buildCommand": "cd src/main/client && npm run build",
  "outputDirectory": "src/main/client/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
